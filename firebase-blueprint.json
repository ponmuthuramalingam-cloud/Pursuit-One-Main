{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A contact form submission lead.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the lead" },
        "email": { "type": "string", "format": "email", "description": "Email address of the lead" },
        "company": { "type": "string", "description": "Company name" },
        "message": { "type": "string", "description": "Message from the lead" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of submission" }
      },
      "required": ["name", "email", "company", "message", "createdAt"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of leads from the contact form."
    }
  }
}
